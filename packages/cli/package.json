{
  "name": "@flowscan/cli",
  "version": "0.1.0",
  "description": "FlowScan CLI - scan repos and serve Kanban board",
  "type": "module",
  "bin": {
    "flowscan": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@flowscan/core": "file:../core",
    "express": "4.21.2",
    "ws": "8.18.0"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/ws": "8.5.13",
    "@types/node": "22.10.5",
    "typescript": "5.7.3",
    "vitest": "2.1.9"
  }
}
